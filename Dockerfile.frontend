FROM node:20-alpine AS build

WORKDIR /app

COPY frontend/package.json /app/package.json
RUN npm install

COPY frontend /app
RUN npm run build

FROM nginx:1.27-alpine

COPY frontend/nginx.conf /etc/nginx/nginx.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 8088

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD wget -q -O - http://127.0.0.1:8088/ >/dev/null 2>&1 || exit 1
